{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "This is an example description! Tell everyone what your mod is about!",
  "authors": [
    "Me!"
  ],
  "contact": {
    "homepage": "https://stonecutter.kikugie.dev/",
    "sources": "https://github.com/RS-256/flashbackLosslessAudioExporter"
  },
  "license": "CC0-1.0",
  "icon": "assets/flae/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.rs256.flae.FLAEMod"
    ],
    "client": [
      "net.rs256.flae.client.FLAEModClient"
    ]
  },
  "mixins": [
    "flae.mixins.json",
    {
      "config": "flaeClient.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "${accesswidener}",
  "depends": {
    "fabricloader": "${fabricLoader}",
    "minecraft": "${minecraft}",
    "${fabricApiKey}": "${fabricAPI}"
  }
}
