{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Exports the audio of a Flashback export as a lossless 32bit float wav, alongside the video.",
  "authors": [
    "RS256"
  ],
  "contact": {
    "homepage": "https://github.com/RS-256/flashbackLosslessAudioExporter",
    "sources": "https://github.com/RS-256/flashbackLosslessAudioExporter"
  },
  "license": "MIT",
  "icon": "assets/flae/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.rs256.flae.client.FLAEModClient"
    ]
  },
  "mixins": [
    {
      "config": "flaeClient.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "${accesswidener}",
  "depends": {
    "fabricloader": "${fabricLoader}",
    "minecraft": "${minecraft}",
    "${fabricApiKey}": "${fabricAPI}",
    "flashback": "*"
  }
}
